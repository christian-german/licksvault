{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "licksvault-companion",
  "version": "0.1.0",
  "identifier": "com.chris.licksvault-companion",
  "build": {
    "frontendDist": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "licksvault-companion",
        "label": "main",
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
