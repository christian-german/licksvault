version: 1
metadata:
  name: licksvault-setup
entries:
  - model: authentik_providers_oauth2.oauth2provider
    identifiers:
      name: "licksvault-oidc"
    attrs:
      client_id: "licksvault-client"
      client_secret: "licksvault-secret"
      redirect_uris:
        - url: "http://localhost:4200/*"
          matching_mode: "strict"
      sub_mode: "hashed_user_id"
      issuer_mode: "per_provider"
  - model: authentik_core.application
    identifiers:
      slug: "licksvault"
    attrs:
      name: "Licksvault"
      provider: !Find [authentik_providers_oauth2.oauth2provider, [name, "licksvault-oidc"]]
